# ── Flask backend ─────────────────────────────────────────────────────────────
FLASK_ENV=production
UPLOAD_FOLDER=/app/uploads
OUTPUT_FOLDER=/app/outputs
CLEANUP_INTERVAL=300
FILE_TIMEOUT=3600

# ── OnlyOffice integration ────────────────────────────────────────────────────

# JWT secret shared between this backend and the OnlyOffice container.
# CHANGE THIS to a long random string in production.
# Must be identical to JWT_SECRET in the onlyoffice service below.
ONLYOFFICE_JWT_SECRET=changeme_replace_in_production

# Enable/disable JWT validation in the OnlyOffice container (true recommended)
ONLYOFFICE_JWT_ENABLED=true

# Port on which OnlyOffice listens on the host (local dev).
ONLYOFFICE_PORT=8080

# URL the *browser* uses to load the OnlyOffice editor UI.
# - Local dev  : http://localhost:8080
# - Production : https://office.yourdomain.com  (if routed via Traefik/nginx)
ONLYOFFICE_URL=http://localhost:8080

# URL the OnlyOffice *server container* uses to reach this Flask backend.
# In Docker Compose this is always the internal service name.
ONLYOFFICE_BACKEND_URL=http://backend:5000
