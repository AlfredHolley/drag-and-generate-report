# Flask Configuration
FLASK_ENV=production

# File Storage Paths
UPLOAD_FOLDER=/app/uploads
OUTPUT_FOLDER=/app/outputs

# Cleanup Service Configuration
CLEANUP_INTERVAL=60
FILE_TIMEOUT=3600

ENABLE_CLEANUP=false
# Gunicorn Configuration (optional, defaults in Dockerfile)
# GUNICORN_WORKERS=2
# GUNICORN_TIMEOUT=120
# CORS - Liste des domaines autorisés (séparés par des virgules)
ALLOWED_ORIGINS=http://localhost:8000,https://report.buchinger-science.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=100
RATE_LIMIT_UPLOAD_PER_HOUR=20

# Authentification (optionnelle)
API_KEY=EKSHBIUWRNIADNCWOJNSOIQENCOS

# Logging sécurisé
SECURE_LOGGING=true
